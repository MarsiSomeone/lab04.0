name: CI

on:
  workflow_dispatch: {}

env:
  BUILD_TYPE: Release

jobs:
  build-and-test:
    strategy:
      matrix:
        include:
          - os: ubuntu-latest
            compiler: gcc
          - os: ubuntu-latest
            compiler: clang
          - os: windows-latest
            compiler: msvc
    runs-on: ${{ matrix.os }}
    steps:

      - name: Checkout source code
        uses: actions/checkout@v4

      
